# Stash connection
STASH_HOST=localhost
STASH_PORT=9999
STASH_HTTPS=false
STASH_API_KEY=

# Provider server
PROVIDER_PORT=3000

# Title format: "title" uses scene.title (fallback: filename), "filename" always uses filename
TITLE_FORMAT=title

# Collection building — add Stash entities as Plex Collections
COLLECTION_FROM_STUDIO=true
COLLECTION_FROM_PARENT_STUDIO=true
COLLECTION_FROM_MOVIE=true
COLLECTION_FROM_PERFORMER=false
COLLECTION_FROM_TAGS=false
COLLECTION_FROM_ORGANIZED=false

# Filtering — skip scenes that don't meet these requirements in match results
REQUIRE_ORGANIZED=false
REQUIRE_STASH_ID=false

# PlexSync round-trip — write Plex ratingKey back to Stash scene URLs
ADD_PLEX_URL=true

# Logging
LOG_LEVEL=info
